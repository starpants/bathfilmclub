---
import type { ThemeFilm } from '@bathfilmclub/types';
import { getPyramidRows, getEmptyBandMessage } from '../utils/pyramid';
import { PyramidIsland } from './PyramidIsland';

interface Props {
  films: ThemeFilm[];
}

const { films } = Astro.props;
const { selected, shortlisted, nominated } = getPyramidRows(films);
const emptyMessage = getEmptyBandMessage(films);
---
<PyramidIsland
  selected={selected}
  shortlisted={shortlisted}
  nominated={nominated}
  emptyMessage={emptyMessage}
  client:load
/>
