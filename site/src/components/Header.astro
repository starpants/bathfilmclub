---
interface Props {
  discordUrl?: string;
}
const { discordUrl = 'https://discord.gg/bathfilmclub' } = Astro.props;
---
<header class="border-b border-neutral-800">
  <div class="max-w-site mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <img
        src="/assets/logo.jpg"
        alt="Bath Film Club"
        class="h-10 w-10 object-cover"
      />
    </a>
    <nav class="flex items-center gap-8">
      <a
        href="/archive"
        class="font-heading font-semibold text-sm uppercase tracking-wide hover:text-brand-red transition-colors"
      >
        Archive
      </a>
      <a
        href={discordUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-discord"
      >
        Join Discord
      </a>
    </nav>
  </div>
</header>
