---
import { MenuDrawer } from './MenuDrawer';
import type { Theme } from '@bathfilmclub/types';

interface Props {
  themes?: Theme[];
  currentSlug?: string;
}

const { themes, currentSlug } = Astro.props;
const isHome = Astro.url.pathname === '/';
---

<header class="border-b-4 border-b-bfc-brand-accent">
  <div class="max-w-site mx-auto px-6 h-16 grid grid-cols-3 items-center">
    <div>
      {
        themes && (
          <MenuDrawer themes={themes} {...(currentSlug ? { currentSlug } : {})} client:load />
        )
      }
    </div>

    <div class="text-center">
      {isHome ? (
        <span class="font-body font-semibold text-sm uppercase tracking-wide text-bfc-brand-fg px-2 py-1">
          Bath Film Club
        </span>
      ) : (
        <a
          href="/"
          class="font-body font-semibold text-sm uppercase tracking-wide text-bfc-brand-fg interactive-item"
        >
          Bath Film Club
        </a>
      )}
    </div>

    <div></div>
  </div>
</header>
