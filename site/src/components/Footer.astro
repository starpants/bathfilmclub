---
// import NavBar from './NavBar.astro';
// import { getAllThemes } from '../utils/data';

interface Props {
  /** Explicit `undefined` allowed: Layout always forwards its own optional prop. */
  bg?: string | undefined;
}

const { bg = 'bg-bfc-brand-alt/10' } = Astro.props;
const year = new Date().getFullYear();
// const allThemes = await getAllThemes();
---

<footer class:list={['py-8', bg]}>
  <div class="max-w-site mx-auto px-6">
    <!-- <NavBar themes={allThemes} /> -->

    <div class="text-center pb-8 capitalize">
      <p class="font-body text-bfc-brand-fg/60 text-sm mb-2">
        &copy; {year} Bath Film Club. All rights reserved.
      </p>
      <p class="font-body text-bfc-brand-fg/60 text-sm">
        Website Designed And Built by
        <div>
          <a
            href="https://meafabula.co.uk"
            class="text-bfc-brand-accent hover:text-bfc-brand-fg transition-colors duration-300"
            >Mea Fabula Studio</a
          >
        </div>
      </p>
    </div>
  </div>
</footer>
