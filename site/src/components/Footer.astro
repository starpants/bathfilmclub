---
import DiscordButton from './DiscordButton.astro';
const year = new Date().getFullYear();
---

<footer class="pt-8">
  <div class="max-w-site mx-auto px-6 py-12 space-y-10">
    <div class="flex items-center justify-center">
      <DiscordButton />
    </div>

    <div class="flex items-center justify-between pt-6 pb-16 border-t-4 border-t-bfc-brand-accent">
      <p class="font-body text-bfc-brand-fg/60 text-sm">
        &copy; {year} Bath Film Club
      </p>
      <nav class="flex gap-6">
        <a href="/" class="font-body text-sm text-bfc-brand-fg/60 hover:text-bfc-brand-fg transition-colors"
          >Home</a
        >
        <a
          href="/search"
          class="font-body text-sm text-bfc-brand-fg/60 hover:text-bfc-brand-fg transition-colors">Search</a
        >
      </nav>
    </div>
  </div>
</footer>
