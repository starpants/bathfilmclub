---
import NavBar from './NavBar.astro';
import { getAllThemes } from '../utils/data';

const year = new Date().getFullYear();
const allThemes = await getAllThemes();
---

<footer class="py-8 bg-bfc-brand-alt/10">
  <div class="max-w-site mx-auto px-6 py-12 space-y-10">
    <NavBar themes={allThemes} />

    <div class="flex justify-center pt-6 pb-8">
      <p class="font-body text-bfc-brand-fg/60 text-sm">
        &copy; {year} Bath Film Club
      </p>
    </div>
  </div>
</footer>
