---
import { MenuDrawer } from './MenuDrawer';
import DiscordButton from './DiscordButton.astro';
import type { Theme } from '@bathfilmclub/types';

interface Props {
  themes?: Theme[];
  currentSlug?: string;
}

const { themes, currentSlug } = Astro.props;
const path = Astro.url.pathname;
const isHome = path === '/';
const isSearch = path === '/search';
const isStats = path === '/stats';
const isTheme = path.startsWith('/theme/');

// Square icon buttons — echo the site's square motif (FilmStrip, section labels, delete box)
const iconBtn = 'p-3 md:p-4 border border-bfc-brand-fg/40 text-bfc-brand-fg/80';
const iconBtnActive = `${iconBtn} cursor-default opacity-40`;
const iconBtnInactive = `${iconBtn} hover:border-bfc-brand-fg hover:text-bfc-brand-fg transition-colors`;
---

<div class="flex flex-wrap items-center justify-center gap-2 md:gap-4">
  {isHome ? (
    <span class={iconBtnActive} aria-label="Home" aria-current="page" title="Home">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <path d="M2 9L10 2l8 7"></path>
        <path d="M4 8v9h4v-5h4v5h4V8"></path>
      </svg>
    </span>
  ) : (
    <a href="/" class={iconBtnInactive} aria-label="Home" title="Home">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <path d="M2 9L10 2l8 7"></path>
        <path d="M4 8v9h4v-5h4v5h4V8"></path>
      </svg>
    </a>
  )}

  {isTheme ? (
    <span class={iconBtnActive} aria-label="Browse themes" aria-disabled="true" title="Browse themes">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M19 17V5a2 2 0 0 0-2-2H4"></path>
        <path d="M8 21h12a2 2 0 0 0 2-2v-1a1 1 0 0 0-1-1H11a1 1 0 0 0-1 1v1a2 2 0 1 1-4 0V5a2 2 0 1 0-4 0v2a1 1 0 0 0 1 1h3"></path>
      </svg>
    </span>
  ) : themes ? (
    <MenuDrawer themes={themes} variant="nav" {...(currentSlug ? { currentSlug } : {})} client:load />
  ) : null}

  {isStats ? (
    <span class={iconBtnActive} aria-label="Club statistics" aria-current="page" title="Statistics">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <path d="M3 3v14h14"></path>
        <path d="M7 17v-4"></path>
        <path d="M11 17v-8"></path>
        <path d="M15 17v-12"></path>
      </svg>
    </span>
  ) : (
    <a href="/stats" class={iconBtnInactive} aria-label="Club statistics" title="Statistics">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <path d="M3 3v14h14"></path>
        <path d="M7 17v-4"></path>
        <path d="M11 17v-8"></path>
        <path d="M15 17v-12"></path>
      </svg>
    </a>
  )}

  {isSearch ? (
    <span class={iconBtnActive} aria-label="Search themes" aria-current="page" title="Search themes">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <circle cx="8" cy="8" r="5"></circle>
        <path d="M12 12l5 5"></path>
      </svg>
    </span>
  ) : (
    <a href="/search" class={iconBtnInactive} aria-label="Search themes" title="Search themes">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
        <circle cx="8" cy="8" r="5"></circle>
        <path d="M12 12l5 5"></path>
      </svg>
    </a>
  )}

  <DiscordButton />
</div>
