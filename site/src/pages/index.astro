---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import FilmPyramid from '../components/FilmPyramid.astro';
import HowItWorks from '../components/HowItWorks.astro';
import SectionTitle from '../components/SectionTitle.astro';
import { getCurrentCycle, formatMonth, formatMeetingDate } from '../utils/data';

const cycle = await getCurrentCycle();
---
<Layout>
  <Header />

  <!-- Hero -->
  <section class="py-20">
    <div class="max-w-site mx-auto px-6 space-y-6">
      <img src="/assets/logo.jpg" alt="Bath Film Club" class="h-20 w-20 object-cover" />
      <h1 class="font-heading font-bold text-5xl md:text-7xl leading-none tracking-tight">
        Bath<br />Film Club
      </h1>
      <p class="font-body text-neutral-300 max-w-md text-lg leading-relaxed">
        A monthly film discussion group in Bath. Each month a new theme, a new selection, a new conversation.
      </p>
      <a
        href="https://discord.gg/bathfilmclub"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-discord"
      >
        Join on Discord
      </a>
    </div>
  </section>

  <main class="max-w-site mx-auto px-6 py-16 space-y-16">
    <HowItWorks />

    {cycle ? (
      <>
        <!-- Current Theme -->
        <section>
          <SectionTitle title="Current Theme" class="mb-4" />
          {cycle.description ? (
            <div class="flex flex-col md:flex-row">
              <div class="flex-[2] border border-neutral-800 p-5 border-b-0 md:border-b md:border-r-0">
                <h3 class="font-heading font-bold text-4xl md:text-5xl leading-tight">{cycle.title}</h3>
              </div>
              <div class="flex-[3] border border-neutral-800 p-5">
                <p class="font-body text-neutral-400 leading-relaxed">{cycle.description}</p>
              </div>
            </div>
          ) : (
            <div class="border border-neutral-800 p-5">
              <h3 class="font-heading font-bold text-4xl md:text-5xl leading-tight">{cycle.title}</h3>
            </div>
          )}
        </section>

        <!-- Upcoming Meeting -->
        {cycle.meeting && (
          <section>
            <SectionTitle title="Upcoming Meeting" class="mb-4" />
            <div class="flex flex-col md:flex-row">
              <div class="flex-[2] border border-neutral-800 p-5 border-b-0 md:border-b md:border-r-0">
                <p class="font-heading font-semibold text-lg leading-tight">{formatMeetingDate(cycle.meeting.date)}</p>
                <p class="font-body text-neutral-400 text-sm mt-1">{cycle.meeting.time}</p>
              </div>
              <div class="flex-[3] border border-neutral-800 p-5">
                {cycle.meeting.venue ? (
                  <p class="font-body text-neutral-400 leading-relaxed">{cycle.meeting.venue}</p>
                ) : (
                  <p class="font-body text-neutral-500 italic text-sm">Venue to be confirmed.</p>
                )}
              </div>
            </div>
          </section>
        )}

        <!-- Film Selection Pyramid -->
        <section>
          <FilmPyramid films={cycle.films} />
        </section>
      </>
    ) : (
      <section>
        <h2 class="section-label mb-4">Current Theme</h2>
        <p class="font-body text-neutral-400 italic">
          The next theme hasn't been announced yet. Join Discord to be the first to know.
        </p>
      </section>
    )}

  </main>
</Layout>
