---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Introduction from '../components/Introduction.astro';
import NextEvent from '../components/NextEvent.astro';
import FilmPyramid from '../components/FilmPyramid.astro';
import { getCurrentCycle, getAllThemes } from '../utils/data';

const cycle = await getCurrentCycle();
const allThemes = await getAllThemes();
---

<Layout>
  <Header themes={allThemes} />
  <main id="main-content">
    <Hero />
    <Introduction />
    <NextEvent cycle={cycle} bg="bg-bfc-brand-alt/10" />
    {cycle && <FilmPyramid films={cycle.films} />}
  </main>
</Layout>
