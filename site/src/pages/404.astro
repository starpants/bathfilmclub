---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Page Not Found — Bath Film Club</title>
    <link rel="icon" type="image/jpeg" href="/assets/logo.jpg" />
  </head>
  <body class="min-h-screen flex items-center justify-center px-6">

    <div class="max-w-2xl w-full text-center space-y-8">

      <h1 class="font-display text-bfc-brand-fg/20 text-[20vw] md:text-[12rem] leading-none" aria-label="404 — Page not found">
        404
      </h1>

      <blockquote class="space-y-4">
        <p class="font-heading font-semibold text-4xl md:text-6xl text-bfc-brand-fg leading-tight">
          "Well, nobody's perfect."
        </p>
        <footer class="font-body text-bfc-brand-fg/60 text-sm tracking-wide">
          — <cite>The Apartment</cite>, Billy Wilder, 1960
        </footer>
      </blockquote>

      <p class="font-body text-bfc-brand-fg/60">
        The page you're looking for doesn't exist.
      </p>

      <a
        href="/"
        class="inline-block font-heading font-semibold text-sm px-3 py-2 md:text-xl md:px-5 md:py-3 border border-bfc-brand-fg/40 text-bfc-brand-fg/80 hover:border-bfc-brand-fg hover:text-bfc-brand-fg transition-colors"
      >
        Back to Home
      </a>

    </div>

  </body>
</html>
