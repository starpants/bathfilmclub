---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import FilmPyramid from '../../components/FilmPyramid.astro';
import LogoLandscape from '../../components/LogoLandscape.astro';
import { getAllThemes, formatMonth } from '../../utils/data';
import type { Theme } from '@bathfilmclub/types';

export async function getStaticPaths() {
  const themes = await getAllThemes();
  return themes.map((theme) => ({
    params: { slug: theme.slug },
    props: { theme },
  }));
}

interface Props {
  theme: Theme;
}
const { theme } = Astro.props;

const allThemes = await getAllThemes();
const currentIndex = allThemes.findIndex((t) => t.slug === theme.slug);
const olderTheme = allThemes[currentIndex + 1] ?? null;
const newerTheme = allThemes[currentIndex - 1] ?? null;
---

<Layout title={theme.title} description={theme.description ?? ''}>
  <Header themes={allThemes} currentSlug={theme.slug} />
  <div class="max-w-site mx-auto px-6 pt-12 pb-4">
    <LogoLandscape class="w-full max-w-md mx-auto fill-bfc-brand-fg" />
  </div>
  <div class="max-w-site mx-auto px-6 py-4">
    <main id="main-content">
      <div class="text-center">
        <p class="section-label justify-center mb-4">{formatMonth(theme.month)}</p>
        <div
          class="flex justify-between items-center font-heading font-black text-5xl leading-tight"
        >
          {
            olderTheme ? (
              <a
                href={`/theme/${olderTheme.slug}`}
                class="text-bfc-brand-fg/60 hover:text-bfc-brand-fg transition-colors"
                aria-label={`Older theme: ${olderTheme.title}`}
              >
                <svg
                  width="16"
                  height="28"
                  viewBox="0 0 10 18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="square"
                  stroke-linejoin="miter"
                >
                  <path d="M8 1L1 9l7 8" />
                </svg>
              </a>
            ) : (
              <span />
            )
          }
          <h1>{theme.title}</h1>
          {
            newerTheme ? (
              <a
                href={`/theme/${newerTheme.slug}`}
                class="text-bfc-brand-fg/60 hover:text-bfc-brand-fg transition-colors"
                aria-label={`Newer theme: ${newerTheme.title}`}
              >
                <svg
                  width="16"
                  height="28"
                  viewBox="0 0 10 18"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="square"
                  stroke-linejoin="miter"
                >
                  <path d="M2 1l7 8-7 8" />
                </svg>
              </a>
            ) : (
              <span />
            )
          }
        </div>
        {
          theme.description && (
            <p class="font-body text-bfc-brand-fg/60 mt-4 max-w-2xl leading-relaxed mx-auto">
              {theme.description}
            </p>
          )
        }
      </div>
    </main>
  </div>
  <FilmPyramid films={theme.films} />
</Layout>
